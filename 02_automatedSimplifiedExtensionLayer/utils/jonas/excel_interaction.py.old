import xlwings as xw
from pathlib import Path

def write_to_excel(path, sheet, cell, val):
    """
    Write a value in a certain cell of an excel file at a location given by path.

    Parameters
    ----------
    path: str
        location of excel file
    sheet: str
        sheet of excel file
    cell: str
        cell of excel sheet
    val: str
        value to be inserted in cell
    """

    # Construct app and load workbook
    app = xw.App(visible=False)
    wb = xw.Book(path)
    ws = wb.sheets[sheet]
    # Update workbook at specified range
    ws.range(cell).options(index=False).value = val
    # Save and close workbook
    wb.save()
    wb.close()
    app.quit()

def read_from_excel(path: Path, sheet: str|int, row: int, column: int) -> str:
    """
    Read a value in a certain cell of an excel file at a location given by path.

    Parameters
    ----------
    path: str
        location of excel file
    sheet: str
        sheet of excel file
    row: int
        row of excel sheet
    column: int
        column of excel sheet 
    val: str
        value to be read
    """

    # Construct app and load workbook
    app = xw.App(visible=False)
    wb = xw.Book(path)
    ws = wb.sheets[sheet]
    # Generate correct column
    excel_cell_dict = {key:value for key, value in zip(range(0,27), list('ABCDEFGHIJKLMNOPQRSTUVWXYZ'))}
    cell = f"{excel_cell_dict[column]}{row}"
    # Read workbook at specified range
    result = str(ws.range(cell).options(index=False).value)
    # Save and close workbook
    wb.close()
    app.quit()
    return result

if __name__ == '__main__':
    pass
